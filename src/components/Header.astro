---
const nav = [
  { label: 'Home',       href: '/' },
  { label: 'The Science', href: '/education' },
  { label: 'Core Program',  href: '/solutions' },
  { label: 'Accelerators',    href: '/tools' },
  { label: 'Contact',   href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-stone-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-6 h-28">

      <!-- Brand -->
      <a href="/" class="flex h-[99px] w-[341px] max-w-[calc(100vw-2rem)] shrink-0 items-center justify-center" aria-label="EmpowerX3 home">
        <img src="/empower-logo-full-color.webp" alt="EmpowerX3" width="341" height="99" aria-hidden="true" class="h-full w-full object-fill" />
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Primary navigation" class="hidden xl:block min-w-0 flex-1">
        <ul class="flex items-center justify-evenly gap-2" role="list">
          {nav.map(({ label, href }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'whitespace-nowrap px-3 py-2.5 rounded-md text-base font-medium tracking-wide transition-colors',
                    isActive
                      ? 'text-gold-500 bg-stone-100'
                      : 'text-charcoal hover:text-gold-500 hover:bg-stone-100',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- CTA -->
      <a
        href="/contact"
        class="hidden xl:inline-flex shrink-0 items-center whitespace-nowrap px-6 py-3 rounded-lg bg-gold-500 text-white text-base font-semibold hover:bg-gold-400 transition-colors"
      >
        Book a Call
      </a>

      <!-- Mobile -->
      <a href="/contact" class="hidden sm:inline-flex xl:hidden text-gold-500 font-semibold text-base hover:text-gold-400 transition-colors">
        Book a Call
      </a>

    </div>
  </div>
</header>
