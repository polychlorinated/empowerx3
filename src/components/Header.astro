---
const nav = [
  { label: 'Home',       href: '/' },
  { label: 'The Science', href: '/education' },
  { label: 'Core Program',  href: '/solutions' },
  { label: 'Accelerators',    href: '/tools' },
  { label: 'Contact',   href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-stone-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-36">

      <!-- Brand -->
      <a href="/" class="flex items-center gap-2.5 font-heading font-bold text-xl tracking-wide" aria-label="EmpowerX3 home">
        <img src="/empower-logo-full-color.webp" alt="EmpowerX3" width="636" height="144" aria-hidden="true" class="shrink-0" />
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Primary navigation">
        <ul class="hidden md:flex items-center gap-1" role="list">
          {nav.map(({ label, href }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'px-4 py-2 rounded-md text-sm font-medium tracking-wide transition-colors',
                    isActive
                      ? 'text-gold-500 bg-stone-100'
                      : 'text-charcoal hover:text-gold-500 hover:bg-stone-100',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- CTA -->
      <a
        href="/contact"
        class="hidden md:inline-flex items-center px-5 py-2.5 rounded-lg bg-gold-500 text-white text-sm font-semibold hover:bg-gold-400 transition-colors"
      >
        Book a Call
      </a>

      <!-- Mobile -->
      <a href="/contact" class="md:hidden text-gold-500 font-semibold text-sm hover:text-gold-400 transition-colors">
        Book a Call
      </a>

    </div>
  </div>
</header>
