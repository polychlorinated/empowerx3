---
const nav = [
  { label: 'Home',      href: '/' },
  { label: 'Education', href: '/education' },
  { label: 'Solutions', href: '/solutions' },
  { label: 'Tools',     href: '/tools' },
  { label: 'Contact',   href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-stone-950/95 backdrop-blur-sm border-b border-stone-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Brand -->
      <a href="/" class="flex items-center gap-2.5 font-heading font-bold text-xl tracking-wide" aria-label="EmpowerX3 home">
        <img src="/favicon.svg" alt="" width="28" height="28" aria-hidden="true" class="shrink-0" />
        <span class="text-cream-100">Empower<span class="text-gold-500">X3</span></span>
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Primary navigation">
        <ul class="hidden md:flex items-center gap-1" role="list">
          {nav.map(({ label, href }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'px-3 py-2 rounded-md text-sm font-medium tracking-wide transition-colors',
                    isActive
                      ? 'text-gold-400 bg-stone-800'
                      : 'text-stone-400 hover:text-cream-100 hover:bg-stone-800',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- CTA -->
      <a
        href="/contact"
        class="hidden md:inline-flex items-center px-4 py-2 rounded-lg bg-gold-500 text-stone-950 text-sm font-semibold hover:bg-gold-400 transition-colors"
      >
        Book a Call
      </a>

      <!-- Mobile -->
      <a href="/contact" class="md:hidden text-gold-500 font-semibold text-sm">
        Book a Call
      </a>

    </div>
  </div>
</header>
