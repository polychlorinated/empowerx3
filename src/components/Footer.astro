---
const year = new Date().getFullYear();
---

<footer class="bg-stone-950 border-t border-stone-800 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Brand column -->
      <div>
        <p class="font-heading font-bold text-cream-100 text-xl tracking-wide mb-1">
          Empower<span class="text-gold-500">X3</span>
        </p>
        <p class="text-gold-600 text-xs font-medium uppercase tracking-widest mb-3">Biohacking For Life Transformation</p>
        <p class="text-sm text-stone-400 leading-relaxed">
          Body. Mind. Spirit. The complete system — because nothing works until everything works together.
        </p>
        <address class="not-italic text-stone-500 text-xs mt-4 leading-relaxed">
          2300 Lohmans Spur #116<br />
          Lakeway, TX 78734
        </address>
      </div>

      <!-- Quick links -->
      <nav aria-label="Footer navigation">
        <p class="font-heading font-semibold text-stone-300 text-sm mb-4 uppercase tracking-widest">Quick Links</p>
        <ul class="space-y-2 text-sm" role="list">
          <li><a href="/education" class="text-stone-400 hover:text-gold-400 transition-colors">Education</a></li>
          <li><a href="/solutions"  class="text-stone-400 hover:text-gold-400 transition-colors">Solutions</a></li>
          <li><a href="/tools"      class="text-stone-400 hover:text-gold-400 transition-colors">Tools</a></li>
          <li><a href="/contact"    class="text-stone-400 hover:text-gold-400 transition-colors">Schedule a Call</a></li>
          <li><a href="/portal"     class="text-stone-400 hover:text-gold-400 transition-colors">Client Portal</a></li>
        </ul>
      </nav>

      <!-- CTA -->
      <div>
        <p class="font-heading font-semibold text-stone-300 text-sm mb-4 uppercase tracking-widest">Ready to Start?</p>
        <p class="text-sm text-stone-400 mb-5 leading-relaxed">
          Book a free 30-minute discovery call. Gary reads every message personally.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 rounded-lg bg-gold-500 text-stone-950 text-sm font-semibold hover:bg-gold-400 transition-colors"
        >
          Book a Discovery Call
        </a>
      </div>

    </div>

    <div class="border-t border-stone-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-stone-600">
      <p>&copy; {year} EmpowerX3. All Rights Reserved.</p>
      <p>
        <a href="/portal"  class="hover:text-stone-400 transition-colors">Client Portal</a>
        &nbsp;·&nbsp;
        <a href="/privacy" class="hover:text-stone-400 transition-colors">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>
