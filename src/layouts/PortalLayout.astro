---
import Head from '@/components/Head.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head
      title={title}
      description="EmpowerX3 client portal — access your program resources and order products."
      noindex={true}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-stone-950 text-cream-100 antialiased">
    <header class="bg-stone-900 border-b border-stone-800 py-4 px-6">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/portal" class="font-heading font-bold text-lg text-cream-100">
          Empower<span class="text-gold-500">X3</span>
          <span class="text-stone-500 font-normal text-sm ml-2">Portal</span>
        </a>
        <a href="/portal/logout" class="text-sm text-stone-400 hover:text-gold-400 transition-colors">
          Sign Out
        </a>
      </div>
    </header>
    <main id="main-content" class="flex-1 max-w-5xl mx-auto w-full px-4 py-8" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
