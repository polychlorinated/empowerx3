---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Biohacking Programs & Custom Plans — EmpowerX3"
  description="Explore EmpowerX3's foundational 12-week Cellular Health program and custom plans for weight loss, recovery, and longevity. The right tires for your specific route."
>

  <!-- ─── Hero ─────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-brand-800 to-accent-600 text-white py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-brand-200 font-semibold text-sm uppercase tracking-widest mb-3">Programs</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl mb-6 max-w-3xl leading-tight">
        Customizing the Vehicle for Your Specific Route
      </h1>
      <p class="text-orange-100 text-xl max-w-2xl leading-relaxed">
        A cross-country trip through the Rockies needs all-terrain tires and a higher gear ratio.
        A coastal drive needs different suspension. Your health goals define the build spec —
        and every client starts with the same foundation.
      </p>
    </div>
  </section>

  <!-- ─── Foundational 12-Week Program ─────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <span class="inline-block px-3 py-1 rounded-full bg-brand-100 text-brand-700 text-sm font-semibold mb-4">
          Every Client Starts Here
        </span>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-gray-900 mb-4">
          The 12-Week Cellular Health Foundation
        </h2>
        <p class="text-gray-500 text-lg">
          You can't put racing tires on a car with a broken axle. Before we customize anything,
          we restore the cellular foundation that makes every other intervention work.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-brand-50 rounded-2xl p-8 border border-brand-100">
          <h3 class="font-heading font-bold text-2xl text-gray-900 mb-4">What's Included</h3>
          <ul class="space-y-3 text-gray-700">
            {[
              'Comprehensive baseline lab panel (cellular markers, hormones, nutrients)',
              'Personalized nutrition protocol based on your specific deficiencies',
              'Targeted supplementation stack — no guesswork, no generic formulas',
              'Weekly 1-on-1 coaching calls with Gary',
              'Movement programming aligned with mitochondrial biogenesis research',
              'Sleep & recovery optimization protocol',
              'Access to the EmpowerX3 client portal and resource library',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-brand-500 mt-0.5 shrink-0" aria-hidden="true">&#10003;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="space-y-4">
          {[
            { week: 'Weeks 1–3', label: 'Assessment & Flush', desc: 'Lab work, baseline measurement, elimination of inflammatory triggers, sleep audit.' },
            { week: 'Weeks 4–7', label: 'Engine Rebuild', desc: 'Targeted micronutrient repletion, mitochondrial support stack, Zone 2 training introduction.' },
            { week: 'Weeks 8–10', label: 'High-Octane Fueling', desc: 'Precision nutrition protocol, refined supplementation, performance tracking.' },
            { week: 'Weeks 11–12', label: 'Route Planning', desc: 'Results review, biomarker re-test, custom long-term plan for your specific goals.' },
          ].map(({ week, label, desc }) => (
            <div class="flex gap-4 p-5 bg-gray-50 rounded-xl border border-gray-100">
              <div class="shrink-0">
                <p class="text-xs font-bold text-brand-600 uppercase tracking-wide">{week}</p>
                <p class="font-heading font-semibold text-gray-900 text-sm mt-0.5">{label}</p>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed border-l border-gray-200 pl-4">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center">
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-4 rounded-xl bg-brand-600 text-white font-bold text-lg hover:bg-brand-700 transition-colors"
        >
          Start the Foundation Program
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Custom Plans ──────────────────────────────────────────────── -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-gray-900 mb-4">
          Then We Customize for Your Route
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto">
          After the foundation, every client's path diverges. Here are the three primary routes.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            terrain: 'Mountain Route',
            plan: 'Weight Loss & Metabolic Reset',
            emoji: '⛰️',
            tagline: 'Steep grades require a higher gear ratio and better fuel economy.',
            points: [
              'Hormonal and metabolic lab panel',
              'Ketogenic or low-inflammatory carb cycling',
              'Mitochondrial fat-oxidation training',
              'Targeted peptide protocols (consult required)',
            ],
          },
          {
            terrain: 'Desert Route',
            plan: 'Recovery & Resilience',
            emoji: '🏜️',
            tagline: 'Extreme conditions demand a cooling system that never fails.',
            points: [
              'Adrenal & cortisol assessment',
              'Anti-inflammatory nutrition protocol',
              'Sleep architecture optimization',
              'Cold/heat exposure programming',
            ],
          },
          {
            terrain: 'Coastal Route',
            plan: 'Longevity & Peak Performance',
            emoji: '🌊',
            tagline: 'The long scenic route — maintaining speed and condition for decades.',
            points: [
              'Full longevity biomarker panel',
              'Senolytics and NAD+ restoration',
              'Cognitive optimization stack',
              'Annual re-test and protocol adjustment',
            ],
          },
        ].map(({ terrain, plan, emoji, tagline, points }) => (
          <article class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="bg-brand-700 text-white p-6">
              <span class="text-4xl block mb-2" aria-hidden="true">{emoji}</span>
              <p class="text-brand-300 text-xs font-bold uppercase tracking-widest">{terrain}</p>
              <h3 class="font-heading font-bold text-xl mt-1">{plan}</h3>
            </div>
            <div class="p-6">
              <p class="text-gray-500 text-sm italic mb-5">{tagline}</p>
              <ul class="space-y-2">
                {points.map((p) => (
                  <li class="flex items-start gap-2 text-sm text-gray-700">
                    <span class="text-brand-500 shrink-0 mt-0.5" aria-hidden="true">&#10003;</span>
                    {p}
                  </li>
                ))}
              </ul>
              <a
                href="/contact"
                class="mt-6 block text-center py-2.5 rounded-lg border-2 border-brand-600 text-brand-600 font-semibold text-sm hover:bg-brand-600 hover:text-white transition-colors"
              >
                Discuss This Route
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
