            phase: 'Short-Term',
            timeline: '1–5 Sessions',
            bullets: ['Immediate stress relief and mental clarity', 'Reduced muscle tension', 'Introduction to cellular optimization'],
          },
          {
            phase: 'Mid-Term',
            timeline: '2–4 Weeks',
            bullets: ['Enhanced skin tone and texture', 'Reduced inflammation and pain', 'More energy and metabolic boost', 'Lymphatic drainage and detoxification', 'Weight loss and better muscle definition'],
          },
          {
            phase: 'Long-Term',
            timeline: '4–12 Weeks+',
            bullets: ['Comprehensive cellular renewal', 'Resilient skin and anti-aging effects', 'Optimized hormonal and nervous system balance', 'Sustainable weight management', 'Lasting vitality and body-mind alignment'],
