    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-medium text-sm text-brand-200">📍 2300 Lohmans Spur #116 · Lakeway, TX 78734 · At Lohman's Crossing</p>
      <a href="/contact" class="text-gold-400 hover:text-gold-300 text-sm font-semibold transition-colors shrink-0">
        Book a Session &rarr;
      </a>
