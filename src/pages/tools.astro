---

<style>
  /* Accordion: hide default marker, add custom chevron */
  details > summary {
    list-style: none;
    cursor: pointer;
  }
  details > summary::-webkit-details-marker { display: none; }

  details > summary .chevron {
    transition: transform 0.2s ease;
  }
  details[open] > summary .chevron {
    transform: rotate(180deg);
  }

  /* Smooth reveal */
  details > .accordion-body {
    animation: slideDown 0.2s ease;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<BaseLayout
  title="ExoPod · Wolfpack · Nutrition — Biohacking Tools | EmpowerX3 Lakeway TX"
  description="EmpowerX3's biohacking tools: the ExoPod 10-in-1 cellular recovery pod, Wolfpack Hill Country hiking group, and genetic-based nutrition & supplement protocols. Lakeway, TX."
>

  <!-- ─── Hero ─────────────────────────────────────────────────────── -->
  <section class="relative bg-stone-950 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-5" aria-hidden="true"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-brand-900/30 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <p class="text-stone-500 font-heading font-semibold text-sm uppercase tracking-widest mb-3">Lakeway · Bee Cave · Austin · Westlake Hills</p>
      <h1 class="font-heading font-bold text-4xl md:text-6xl mb-4 max-w-3xl leading-tight text-cream-100">
        Biohacking Tools & Programs
      </h1>
      <p class="text-stone-300 text-lg max-w-2xl leading-relaxed">
        Three pillars that accelerate your transformation: the ExoPod for cellular recovery,
        the Wolfpack for accountability in the field, and precision nutrition built from your own genetic data.
      </p>
    </div>
  </section>

  <!-- ─── In-Page Nav ───────────────────────────────────────────────── -->
  <nav aria-label="Page sections" class="sticky top-16 z-40 bg-stone-950/95 backdrop-blur-sm border-b border-stone-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="flex overflow-x-auto gap-0" role="list">
        {[
          { label: 'ExoPod',                  href: '#exopod'    },
          { label: 'Wolfpack',                href: '#wolfpack'  },
          { label: 'Nutrition & Supplements', href: '#nutrition' },
        ].map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="block px-5 py-4 text-sm font-semibold text-stone-400 hover:text-gold-400 hover:border-b-2 hover:border-gold-500 whitespace-nowrap transition-colors"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- EXOPOD SECTION                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section id="exopod" class="scroll-mt-32 pt-20 pb-4 bg-stone-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-2">
        <span class="text-4xl" aria-hidden="true">🛸</span>
        <div>
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-cream-100">The ExoPod</h2>
          <p class="text-gold-400 font-semibold">10 Therapies · One Session · 30 Minutes · No Downtime</p>
        </div>
      </div>
      <p class="text-stone-400 max-w-3xl leading-relaxed mt-4 mb-2">
        A clinical-grade biohacking tool delivering 10 advanced cellular therapies in a single session.
        Inflammation, slow recovery, and premature aging aren't character flaws — they're cellular problems
        that require cellular solutions.
      </p>
    </div>
  </section>

  <!-- Location bar -->
