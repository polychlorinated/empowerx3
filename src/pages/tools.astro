  },
  {
    name: 'O3 Cleanse™',
    subtitle: 'Medical-Grade Ozone Disinfection Between Every Session',
    feel: 'A clean, fresh scent — all that remains after ozone dissipates into pure oxygen.',
    benefits: [
      'Medical-grade ozone neutralizes viruses, bacteria, and mold between every client.',
      'Zero residue — the ozone rapidly dissipates, leaving a perfectly sanitized environment.',
    ],
  },
  {
    name: 'Integrated Infrared Heat & Convection',
    subtitle: 'Detoxifying Thermal Environment for Weight Loss & Recovery',
    feel: 'A deep, even warmth that builds gradually throughout the session.',
    benefits: [
      'Promotes elimination of stored toxins through sweat.',
      'Deep internal heat supports weight loss and improves muscle definition.',
    ],
  },
];

const faqs = [
  {
    q: 'What should I wear during my ExoPod session?',
    a: "Minimal clothing or swimwear is recommended — the Photon Glow™ and DeepWave™ therapies need to penetrate the skin directly. If your hair is long, plan to wear it up.",
  },
  {
    q: 'How should I prepare for my session?',
    a: "Drink plenty of water beforehand. Don't come on a full stomach. Expect to relax and absorb the benefits — simplicity is core to the EmpowerX3 experience.",
  },
  {
    q: 'How often should I use the ExoPod?',
    a: "2–3 times per week is recommended for significant weight loss and long-term anti-aging results. If you're in our 90-Day coaching program, you can combine coaching calls with your ExoPod visits.",
  },
  {
    q: 'Is the ExoPod safe?',
    a: "Yes. The ExoPod uses non-invasive, non-ionizing frequencies. The O3 Cleanse™ system ensures the pod is 99.9% sanitized between every client.",
  },
  {
    q: 'What results can I expect, and when?',
    a: "Within a week: immediate relaxation and stress relief. After a few weeks: improved skin tone, texture, and weight loss benefits. Every body is unique — that's why we track your results throughout.",
  },
