---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';

const therapies = [
  {
    name: 'BioAlign™ Balance Therapy',
    subtitle: 'Rotating Magnetic Field for Nervous System Reset',
    feel: 'A gentle, grounding sensation. Many clients report their "mind finally quiets" during this phase.',
    benefits: [
      'Shifts your body from "fight or flight" (sympathetic) to "rest and digest" (parasympathetic) — foundational for recovery, digestion, and stress resilience.',
      'Red blood cells move more freely, improving oxygen and nutrient delivery to every cell.',
      'Addresses electromagnetic imbalances that contribute to fatigue and inflammation.',
    ],
  },
  {
    name: 'Oxygen Ion Air Therapy',
    subtitle: 'Negative Ion Infusion for Mental Clarity & Mood',
    feel: 'A sensation of "freshness" and mental clarity. Many clients say it feels like stepping outside after a rainstorm.',
    benefits: [
      'Negative ions increase serotonin levels, improving mood, focus, and mental clarity — the same reason you feel better after being in nature.',
      'Opens airways and improves lung function, especially for those with indoor allergies or respiratory sensitivity.',
      'Binds to dust, bacteria, and pollutants, effectively cleaning the air you breathe during your session.',
    ],
  },
  {
    name: 'DeepWave™ Energy Therapy',
    subtitle: 'Terahertz Frequency for Cellular Network & ATP Production',
    feel: 'A deep, penetrating warmth from the inside out. Clients describe it as a "cellular massage" that relaxes muscles you didn\'t know were tense.',
    benefits: [
      'Stimulates ATP (adenosine triphosphate) production — your cells\' primary energy currency. More ATP = more cellular energy = better function, repair, and vitality.',
      'Warms tissues from the inside out, releasing muscle tension and stiffness without the extreme heat of traditional saunas.',
      'Improves how your cells "talk" to each other, supporting coordinated repair and optimization throughout the body.',
    ],
  },
  {
    name: 'Photon Glow™ Light Therapy',
    subtitle: 'Red & Near-Infrared Light for Mitochondrial Health',
    feel: 'A gentle, soothing warmth. Many clients find this the most relaxing part of the session.',
    benefits: [
      'Red Light (630–660nm) targets surface tissues to smooth fine lines, even skin tone, and boost collagen production by up to 400%.',
      'Near-Infrared (850–940nm) penetrates deeper to support muscle recovery, joint health, reduce inflammation, and optimize mitochondrial function.',
      'Addresses cellular aging at the root — not just masking it.',
    ],
  },
  {
    name: 'Chromotherapy (Ambient Light)',
    subtitle: 'Customizable Color Environment for Emotional & Hormonal Balance',
    feel: 'Deeply calming. Choose your color based on your session goal.',
    benefits: [
      'Calming amber for grounding, cool blue for mental clarity, or pink for heart-centered energy.',
      'Helps signal natural melatonin release — ideal for improving sleep and combatting seasonal affective symptoms.',
    ],
  },
  {
    name: 'Resonance Pulse™ Therapy',
    subtitle: 'Vibration Wave for Lymphatic Drainage',
    feel: 'Like a professional lymphatic massage without the hands.',
    benefits: [
      'Moves stagnant fluids and toxins, reducing bloating and improving overall mobility.',
      'Frequencies tuned to support bioresonance, helping recalibrate your body\'s internal rhythms.',
    ],
  },
  {
    name: 'O3 Cleanse™ (Ozone Disinfection)',
    subtitle: '99.9% Sanitization Between Every Session',
    feel: 'A clean, fresh scent — the only thing left after the ozone dissipates into pure oxygen.',
    benefits: [
      'Medical-grade ozone (O3) neutralizes viruses, bacteria, and mold between every client.',
      'Zero residue — the ozone rapidly dissipates, leaving only a perfectly sanitized environment.',
    ],
  },
  {
    name: 'Integrated Infrared Heat & Convection',
    subtitle: 'Detoxifying Thermal Environment',
    feel: 'A deep, even warmth that builds gradually.',
    benefits: [
      'Promotes elimination of stored toxins through sweat.',
      'Deep internal heat supports weight loss and improves muscle definition.',
    ],
  },
];

const faqs = [
  {
    q: 'What should I wear during my ExoPod session?',
    a: 'To maximize the benefits of the Photon Glow™ and DeepWave™ therapies, minimal clothing or swimwear is recommended — the light and heat need to penetrate the skin directly. If your hair is long, plan to wear it up during treatment.',
  },
  {
    q: 'How should I prepare for my session?',
    a: 'Drink plenty of water before your visit. Don\'t come on a full stomach. Expect to relax and absorb the benefits — simplicity is core to the EmpowerX3 experience.',
  },
  {
    q: 'How often should I use the ExoPod?',
    a: 'While many feel immediate relief after one session, consistent use (2–3 times per week) is recommended for significant weight loss and long-term anti-aging results. If you\'re in our 90-Day coaching program, you can combine coaching calls with your ExoPod visits.',
  },
  {
    q: 'Is ExoPod safe?',
    a: 'Yes. The ExoPod uses non-invasive, non-ionizing frequencies. The O3 Cleanse™ system ensures the pod is 99.9% sanitized between every client.',
  },
  {
    q: 'What results can I expect?',
    a: 'Within a week: immediate relaxation and stress relief. After a few weeks: improved skin tone, texture, and weight loss benefits. Every body is unique and will respond in its own way — that\'s why we track your results throughout.',
  },
];
---

<BaseLayout
  title="ExoPod Biohacking Lakeway TX — 10-in-1 Cellular Recovery | EmpowerX3"
  description="EmpowerX3's ExoPod delivers 10 advanced cellular therapies in one 30-minute session. Red light, magnetic field therapy, oxygen ions, and more. Serving Lakeway, Austin, Bee Cave & Westlake Hills."
>

  <!-- ─── Hero ─────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-gray-900 to-brand-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gray-400 font-semibold text-sm uppercase tracking-widest mb-3">Lakeway · Bee Cave · Austin · Westlake Hills</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl mb-4 max-w-3xl leading-tight">
        Biohacking Lakeway: Reset Your Biology with ExoPod Therapy
      </h1>
      <p class="text-accent-400 font-bold text-xl mb-6">Recover Faster. Burn Smarter. Recharge in 30 Minutes.</p>
      <p class="text-gray-300 text-lg max-w-2xl leading-relaxed mb-8">
        The ExoPod is a clinical-grade biohacking tool that delivers 10 advanced therapies in one 30-minute session.
        Inflammation, slow recovery, and premature aging aren't character flaws — they're cellular problems.
        And cellular problems require cellular solutions.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-6 py-3 rounded-xl bg-accent-500 text-white font-semibold text-lg hover:bg-accent-600 transition-colors"
      >
        Book Your Consultation
      </a>
    </div>
  </section>

  <!-- ─── Location ──────────────────────────────────────────────────── -->
  <section class="bg-brand-700 text-white py-6">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-semibold">
        📍 Visit us at Lohman's Crossing — 2300 Lohmans Spur #116, Lakeway, TX 78734
      </p>
      <a href="/contact" class="text-brand-200 hover:text-white text-sm font-medium transition-colors shrink-0">
        Get Directions &rarr;
      </a>
    </div>
  </section>

  <!-- ─── Benefits Timeline ─────────────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-gray-900 mb-4 text-center">
        What to Expect — and When
      </h2>
      <p class="text-gray-500 text-center max-w-2xl mx-auto mb-12">
        Results build over time. Here's the typical progression.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            phase: 'Short-Term',
            timeline: '1–5 Sessions',
            bullets: [
              'Immediate stress relief and mental clarity',
              'Reduced muscle tension',
              'Introduction to cellular optimization',
              'Perfect for testing the protocol',
            ],
          },
          {
            phase: 'Mid-Term',
            timeline: '2–4 Weeks',
            bullets: [
              'Enhanced skin tone and texture',
              'Reduced inflammation and pain',
              'More energy and metabolic boost',
              'Lymphatic drainage and detoxification',
              'Weight loss and better muscle definition',
            ],
          },
          {
            phase: 'Long-Term',
            timeline: '4–12 Weeks and Beyond',
            bullets: [
              'Comprehensive cellular renewal',
              'Resilient skin and anti-aging effects',
              'Optimized hormonal and nervous system balance',
              'Sustainable weight management',
              'Lasting vitality and body-mind alignment',
            ],
          },
        ].map(({ phase, timeline, bullets }) => (
          <div class="bg-brand-50 rounded-2xl p-8 border border-brand-100">
            <p class="text-brand-600 font-bold text-sm uppercase tracking-widest mb-1">{phase}</p>
            <p class="font-heading font-semibold text-gray-900 text-lg mb-4">{timeline}</p>
            <ul class="space-y-2">
              {bullets.map((b) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="text-brand-500 shrink-0 mt-0.5" aria-hidden="true">✓</span>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Case Studies ──────────────────────────────────────────────── -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-gray-900 mb-12 text-center">
        Real Results from Real Clients
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <article class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <p class="text-accent-500 font-bold text-2xl mb-1">6 Inches Lost</p>
          <p class="text-gray-500 text-sm mb-5">in just 4 sessions — Postpartum</p>
          <p class="text-gray-600 leading-relaxed mb-5">
            Ava is a busy 34-year-old mother. She wanted to shed pounds added during her pregnancy,
            but her time is precious and she's prioritizing solutions that are as natural and effective as possible.
          </p>
          <ul class="space-y-2">
            {[
              'Lost 6 inches overall in just 4 sessions',
              'Reduced bloating and tightened loose skin around her abdomen',
              'Felt more confident and energized throughout the day',
            ].map((r) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-brand-500 shrink-0" aria-hidden="true">✓</span>
                {r}
              </li>
            ))}
          </ul>
        </article>
        <article class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <p class="text-accent-500 font-bold text-2xl mb-1">7 Inches Lost</p>
          <p class="text-gray-500 text-sm mb-5">over 5 sessions — Athletic Performance</p>
          <p class="text-gray-600 leading-relaxed mb-5">
            Michael is 42 and an intense weightlifter who continued to struggle with stubborn fat
            and muscle soreness despite his training. He wanted a non-invasive way to accelerate fat
            loss and enhance recovery.
          </p>
          <ul class="space-y-2">
            {[
              'Lost 7 inches across his midsection after 5 sessions',
              'Improved muscle recovery and reduced post-workout soreness',
              'Increased energy levels and circulation for better athletic performance',
            ].map((r) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-brand-500 shrink-0" aria-hidden="true">✓</span>
                {r}
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ─── 10 Therapies ──────────────────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-gray-900 mb-4 text-center">
        10 Cellular Therapies. One 30-Minute Session.
      </h2>
      <p class="text-gray-500 text-center max-w-2xl mx-auto mb-14">
        This isn't "wellness theater" — every modality targets specific cellular mechanisms to reduce
        inflammation, boost energy production, and accelerate recovery.
      </p>
      <div class="space-y-6">
        {therapies.map(({ name, subtitle, feel, benefits }, i) => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <div class="flex items-start gap-4 mb-4">
              <span class="shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center font-bold text-sm">
                {i + 1}
              </span>
              <div>
                <h3 class="font-heading font-bold text-xl text-gray-900">{name}</h3>
                <p class="text-brand-600 text-sm font-medium">{subtitle}</p>
              </div>
            </div>
            <p class="text-gray-500 text-sm italic mb-4 ml-12">
              <strong class="text-gray-700 not-italic">What you feel:</strong> {feel}
            </p>
            <ul class="space-y-2 ml-12">
              {benefits.map((b) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="text-brand-500 shrink-0 mt-0.5" aria-hidden="true">✓</span>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Why EmpowerX3 ─────────────────────────────────────────────── -->
  <section class="py-20 bg-brand-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading font-bold text-3xl text-gray-900 mb-6">
            We're Not a Spa. We're a Biohacking Center.
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            At EmpowerX3, Gary Brandt and our team understand that weight loss is about more than
            just a number on a scale. We combine the cutting-edge technology of the ExoPod with a
            holistic approach to healing your body.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            Whether you want to manage sleep better, lose weight, or improve your libido, we tailor
            our solutions to help you reach your goals fast.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Located conveniently in Lakeway — perfect for residents of Austin, West Lake Hills,
            Bee Cave, and Cedar Park — our facility is a dedicated biohacking destination for those
            who want to optimize their health without pharmaceuticals.
          </p>
          <p class="text-gray-600 leading-relaxed">
            The ExoPod is powerful, but it's one tool. Our 90-Day Program includes biohacking life
            coaching to address sleep, nutrition, stress management, and supplementation — the factors
            that determine whether you thrive or just survive.
          </p>
        </div>
        <div class="space-y-4">
          <a
            href="/contact"
            class="block w-full py-4 rounded-xl bg-brand-600 text-white font-bold text-center text-lg hover:bg-brand-700 transition-colors"
          >
            Contact Us to Get Started
          </a>
          <div class="bg-white rounded-xl p-6 border border-brand-100">
            <p class="font-semibold text-gray-900 mb-1">Visit Our Wellness Center</p>
            <address class="not-italic text-gray-600 text-sm leading-relaxed">
              2300 Lohmans Spur #116<br />
              Lakeway, TX 78734<br />
              At Lohman's Crossing
            </address>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Wolfpack ──────────────────────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-6xl block mb-4" aria-hidden="true">🐺</span>
      <h2 class="font-heading font-bold text-3xl text-gray-900 mb-4">
        Want to Explore Hill Country with Other Guys?
      </h2>
      <p class="text-gray-600 leading-relaxed mb-8 max-w-2xl mx-auto">
        The Wolfpack Hiking Group is EmpowerX3's community component — monthly group hikes through
        Hill Country where clients test their rebuilt bodies against real terrain and discover that
        the protocols actually work. We organize hikes to motivate each other as we take on new challenges.
      </p>
      <a href="/contact" class="inline-flex items-center px-6 py-3 rounded-xl bg-brand-600 text-white font-semibold hover:bg-brand-700 transition-colors">
        Join the Wolfpack
      </a>
    </div>
  </section>

  <!-- ─── FAQ ───────────────────────────────────────────────────────── -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl text-gray-900 mb-10 text-center">
        Frequently Asked Questions
      </h2>
      <div class="space-y-6">
        {faqs.map(({ q, a }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <h3 class="font-heading font-semibold text-gray-900 mb-2">{q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
