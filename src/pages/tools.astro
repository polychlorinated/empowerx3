        ].map(({ icon, title, body }) => (
          <div class="bg-stone-800 rounded-2xl p-6 border border-stone-700">
            <span class="text-3xl block mb-3" aria-hidden="true">{icon}</span>
            <h3 class="font-heading font-bold text-lg text-cream-100 mb-2">{title}</h3>
            <p class="text-stone-400 text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <div class="bg-stone-800 rounded-2xl p-8 border border-stone-700 max-w-3xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-gold-500 to-gold-800 rounded-l-2xl" aria-hidden="true"></div>
        <h3 class="font-heading font-bold text-xl text-cream-100 mb-4 pl-4">
          Why Generic Supplements Don't Work
