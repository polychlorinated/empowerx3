      </p>
      <div class="space-y-2">
        {therapies.map(({ name, subtitle, feel, benefits }, i) => (
          <details class="group border border-stone-800 rounded-xl overflow-hidden bg-stone-900">
            <summary class="flex items-center justify-between gap-4 px-6 py-4 hover:bg-stone-800 transition-colors">
              <div class="flex items-center gap-4 min-w-0">
                <span class="shrink-0 w-7 h-7 rounded-full bg-brand-900 text-brand-400 flex items-center justify-center font-bold text-xs">
