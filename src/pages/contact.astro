---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactSchema from '@/components/schema/ContactSchema.astro';
---

<BaseLayout
  title="Book a Discovery Call — EmpowerX3"
  description="Schedule your free 30-minute discovery call with Gary. Map out your cellular health route and learn what an EmpowerX3 program looks like for your specific goals."
>
  <!-- ContactSchema injected into the <head> via named slot — only on this page -->
  <ContactSchema slot="head" />

  <!-- ─── Hero ─────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-brand-700 to-brand-900 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-300 font-semibold text-sm uppercase tracking-widest mb-3">Get Started</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl mb-6">
        Let's Map Out Your Route
      </h1>
      <p class="text-brand-100 text-xl max-w-2xl mx-auto leading-relaxed">
        A 30-minute call with Gary. No pressure, no sales pitch — just an honest assessment of
        where your cellular engine is today and what the road ahead could look like.
      </p>
    </div>
  </section>

  <!-- ─── Scheduling + Contact ──────────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">

        <!-- Left: What to expect -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-gray-900 mb-6">What Happens on the Call</h2>
          <div class="space-y-6">
            {[
              { num: '1', title: 'Tell Gary Where You Are', body: 'Energy levels, health history, what you\'ve already tried. No judgment — just context.' },
              { num: '2', title: 'Map Out Your Destination', body: 'Weight loss, more energy, longevity, recovery — what does success actually look like for you?' },
              { num: '3', title: 'Get an Honest Assessment', body: 'Gary will tell you whether EmpowerX3 is the right fit — and which route makes sense if it is.' },
            ].map(({ num, title, body }) => (
              <div class="flex gap-4">
                <div class="shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center font-bold text-sm">
                  {num}
                </div>
                <div>
                  <h3 class="font-heading font-semibold text-gray-900 mb-1">{title}</h3>
                  <p class="text-gray-600 text-sm leading-relaxed">{body}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-10 p-6 bg-brand-50 rounded-xl border border-brand-100">
            <p class="text-brand-800 font-semibold mb-1">Prefer to reach out directly?</p>
            <p class="text-brand-700 text-sm">
              Email: <a href="mailto:gary@empowerx3.com" class="underline hover:text-brand-900">gary@empowerx3.com</a>
            </p>
          </div>
        </div>

        <!-- Right: Web3Forms contact form — zero JS, native browser POST -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-gray-900 mb-6">Send Us a Message</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-5"
          >
            <input type="hidden" name="access_key" value="f5cf5af3-bf0f-41e5-a70a-4ad893d57cd1" />
            <input type="hidden" name="subject" value="New inquiry from EmpowerX3.com" />
            <input type="hidden" name="redirect" value="https://empowerx3.com/thank-you" />
            <!-- Honeypot — bots fill this, humans don't -->
            <input type="checkbox" name="botcheck" class="hidden" aria-hidden="true" />

            <div>
              <label for="contact-name" class="block text-sm font-medium text-gray-700 mb-1.5">
                Full Name <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                autocomplete="name"
                placeholder="Jane Smith"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="contact-email" class="block text-sm font-medium text-gray-700 mb-1.5">
                Email Address <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                placeholder="jane@example.com"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="contact-phone" class="block text-sm font-medium text-gray-700 mb-1.5">
                Phone <span class="text-gray-400 font-normal">(optional)</span>
              </label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                autocomplete="tel"
                placeholder="+1 (555) 000-0000"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="contact-goal" class="block text-sm font-medium text-gray-700 mb-1.5">
                What's your primary goal?
              </label>
              <select
                id="contact-goal"
                name="goal"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
              >
                <option value="">Select one…</option>
                <option value="energy">More energy &amp; less fatigue</option>
                <option value="weight">Weight loss &amp; metabolic reset</option>
                <option value="recovery">Faster recovery</option>
                <option value="longevity">Longevity &amp; peak performance</option>
                <option value="other">Something else</option>
              </select>
            </div>

            <div>
              <label for="contact-message" class="block text-sm font-medium text-gray-700 mb-1.5">
                Tell Gary a bit about where you are <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="4"
                placeholder="What's been going on, what have you tried, what made you reach out…"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-3 rounded-xl bg-brand-600 text-white font-semibold text-base hover:bg-brand-700 transition-colors"
            >
              Send My Message
            </button>

            <p class="text-xs text-gray-400 text-center">
              No spam, ever. Gary reads every message personally.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
