# Copy to .env and fill in values — never commit .env
WPGRAPHQL_ENDPOINT=https://wp.empowerx3.com/graphql
WP_GRAPHQL_AUTH_TOKEN=your_wp_graphql_auth_token_here

# Site URL for canonical URLs, sitemaps, OG tags
SITE_URL=https://empowerx3.com

# Preview mode secret (shared with WordPress)
PREVIEW_SECRET=your_preview_secret_here

# Portal auth — store a bcrypt hash of the password
# Generate with: npx @astrojs/password hash yourpassword
# TEMPORARY: For dev only, set PORTAL_PASSWORD=yourpassword in .env
PORTAL_PASSWORD_HASH=your_bcrypt_hash_here

# Optional: secret token used by WP Deploy Hook to validate build triggers
DEPLOY_HOOK_SECRET=your_webhook_secret_here
